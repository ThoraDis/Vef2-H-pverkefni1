generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Data model
model Event {
  id        Int     @id @default(autoincrement())
  title     String
  description   String
  soldOut Boolean @default(false)
  images Image[]
  media Media @relation(fields: [])
  
  place   Place @relation(fields: [placeID, placeEmail], references: [id, email])
  placeID  Int
  placeEmail String
}

model Place {
  id    Int     @id @default(autoincrement())
  email String  @unique
  address  String
  events Event[]
  @@unique([id, email])
}

model Image {
  image String @unique
  timeStamp DateTime @default(now())
  event Event @relation(fields: [eventId], references: [id])
  eventId Int
}

model Media {
  eventId Int
  placeEmail String
  facebook  String? @unique
  website   String
}

model Tickets {

}

model User {

}
