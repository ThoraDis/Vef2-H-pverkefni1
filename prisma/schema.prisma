// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id        Int     @id @default(autoincrement())
  title     String
  description   String
  soldOut Boolean @default(false)

  ticketsForSale Ticket[]
  images Image[]
  media Media?

  place   Place @relation(fields: [placeID], references: [id])
  placeID  Int
}

model Place {
  id    Int     @id @default(autoincrement())
  email String  @unique
  address  String
  events Event[] //Einn staður getur haft mörg Event, t.d. Harpa
}

model Image {
  id  Int @id @default(autoincrement())
  image String @unique
  timeStamp DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id])
  eventId Int
}

model Media {
  id  Int @id @default(autoincrement())

  event Event @relation(fields: [eventId], references: [id])
  eventId Int @unique
  
  facebook  String?
  website   String?
}

model Ticket {
  id  Int @id @default(autoincrement())

  event Event @relation(fields: [eventId], references: [id])
  eventId Int

  userId Int?
  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([eventId, userId])
}

model User {
  id  Int @id @default(autoincrement())
  email String @unique

  tickets Ticket[]
}
